---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DotField from '../components/DotField/DotField.jsx';
import '../styles/global.css';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title} | Roman Golev</title>
    <meta name="description" content="Roman Golev's Portfolio Website" />
    <script is:inline>
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body>
    <div class="bg-dot-field">
      <DotField client:only="react" glowColor="transparent" />
    </div>
    <div class="site-wrapper">
      <Header />
      <main class="main-content">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      import { createLiquidGlass } from '../lib/liquid-glass.js';

      const instances = [];

      function initLiquidGlass() {
        document.querySelectorAll('.glass-panel').forEach((el) => {
          instances.push(
            createLiquidGlass(el, {
              borderRadius: 12,
              scale: -140,
              aberration: [0, 6, 12],
              blur: 10,
              saturation: 1.2,
              fallbackFilter: 'blur(3px)',
            })
          );
        });
      }

      // Defer one frame so panel dimensions are settled before sampling.
      requestAnimationFrame(initLiquidGlass);
    </script>
  </body>
</html>

<style>
  .bg-dot-field {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .site-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
  }

  .main-content {
    flex: 1 0 auto;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    position: relative;
    z-index: 1;
  }
</style>